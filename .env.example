# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///./requisicoes.db

# Oracle (descomentar ao migrar):
# DATABASE_TYPE=oracle
# DATABASE_URL=oracle+oracledb://usuario:senha@servidor:1521/ORCL

# ─── Segurança ────────────────────────────────────────────────────────────────
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mude-esta-chave-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── SMTP Locaweb ─────────────────────────────────────────────────────────────
SMTP_HOST=email.locaweb.com.br
SMTP_PORT=587
SMTP_USER=requisicoes@pinheiroferragens.com.br
SMTP_PASSWORD=sua-senha-aqui
SMTP_FROM=requisicoes@pinheiroferragens.com.br

# ─── WhatsApp (Evolution API self-hosted) ─────────────────────────────────────
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=sua-api-key
WHATSAPP_INSTANCE=pinheiro

# ─── Pasta compartilhada (servidor de arquivos) ───────────────────────────────
SHARED_FOLDER_PATH=\\servidor\requisicoes
